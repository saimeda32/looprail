{
  "name": "looprail",
  "version": "0.1.0",
  "description": "Run your coding agent in a loop until the work is verified done, not until the model stops talking",
  "license": "MIT",
  "type": "module",
  "author": "Sai Kiran Meda",
  "repository": { "type": "git", "url": "git+https://github.com/saimeda32/looprail.git" },
  "homepage": "https://github.com/saimeda32/looprail#readme",
  "bugs": { "url": "https://github.com/saimeda32/looprail/issues" },
  "keywords": ["ai", "agent", "agents", "llm", "orchestration", "claude", "codex", "aider", "loop", "cli"],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "looprail": "./dist/cli/index.js" },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "bash scripts/e2e.sh"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
